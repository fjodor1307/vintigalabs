{
  "name": "vintiga-prototypes",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "contributors": "node scripts/generate-contributors.mjs",
    "new-prototype": "node scripts/new-prototype.mjs",
    "clone-prototype": "node scripts/clone-prototype.mjs",
    "generate-index": "node scripts/generate-index.mjs",
    "install-hooks": "node scripts/install-hooks.mjs",
    "postinstall": "node scripts/install-hooks.mjs",
    "predev": "node scripts/generate-contributors.mjs && node scripts/generate-index.mjs && node scripts/generate-updates.mjs",
    "prebuild": "node scripts/generate-contributors.mjs && node scripts/generate-index.mjs && node scripts/generate-updates.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "updates": "node scripts/generate-updates.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tailwindcss/vite": "^4.2.2",
    "jszip": "^3.10.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.35.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "agentation": "^3.0.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wrangler": "^4.87.0"
  }
}
